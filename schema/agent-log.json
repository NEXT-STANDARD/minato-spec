{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NEXT-STANDARD/minato-spec/blob/main/schema/agent-log.json",
  "title": "AgentLog",
  "description": "MINATO 0x37 AGENT_LOG. Post-hoc notification of an autonomous action taken by an agent in auto/full_auto mode. See MINATO_PROTOCOL.md §5, §10.",
  "type": "object",
  "required": ["type", "version", "from", "to", "timestamp", "nonce", "payload", "signature"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "AGENT_LOG"
    },
    "version": { "$ref": "common.json#/definitions/minato_version" },
    "from": { "$ref": "common.json#/definitions/npub" },
    "to": { "$ref": "common.json#/definitions/npub" },
    "timestamp": { "$ref": "common.json#/definitions/unix_timestamp" },
    "nonce": { "$ref": "common.json#/definitions/nonce" },
    "payload": {
      "type": "object",
      "description": "AGENT_LOG payload. Receivers should deduplicate by (from, log_id).",
      "required": ["log_id", "action", "trust_mode", "content"],
      "properties": {
        "log_id": {
          "description": "Idempotency key for this log entry.",
          "type": "string",
          "minLength": 1
        },
        "action": { "$ref": "common.json#/definitions/agent_log_action" },
        "intent": { "$ref": "common.json#/definitions/intent" },
        "trust_mode": { "$ref": "common.json#/definitions/trust_mode" },
        "content": {
          "description": "Human-readable summary of the autonomous action.",
          "type": "string",
          "minLength": 1
        },
        "context": {
          "description": "Optional structured metadata for implementation-specific audit details.",
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "signature": { "$ref": "common.json#/definitions/signature" }
  }
}
