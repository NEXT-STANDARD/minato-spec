{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NEXT-STANDARD/minato-spec/blob/main/schema/agent-revoke.json",
  "title": "AgentRevoke",
  "description": "MINATO 0x35 AGENT_REVOKE. Revokes local trust, a remote Agent Card, or the whole agent relationship. See MINATO_PROTOCOL.md §5, §10.",
  "type": "object",
  "required": ["type", "version", "from", "to", "timestamp", "nonce", "payload", "signature"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "const": "AGENT_REVOKE"
    },
    "version": { "$ref": "common.json#/definitions/minato_version" },
    "from": { "$ref": "common.json#/definitions/npub" },
    "to": { "$ref": "common.json#/definitions/npub" },
    "timestamp": { "$ref": "common.json#/definitions/unix_timestamp" },
    "nonce": { "$ref": "common.json#/definitions/nonce" },
    "payload": {
      "type": "object",
      "description": "AGENT_REVOKE payload. Receivers should treat a missing scope as 'all'.",
      "required": ["intent"],
      "properties": {
        "intent": {
          "type": "string",
          "const": "connection.terminate"
        },
        "scope": { "$ref": "common.json#/definitions/revoke_scope" },
        "reason": {
          "description": "Optional human-readable reason for local logs or UI.",
          "type": "string",
          "maxLength": 512
        },
        "context": {
          "description": "Optional structured context for implementation-specific revoke metadata.",
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "signature": { "$ref": "common.json#/definitions/signature" }
  }
}
